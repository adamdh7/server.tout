                row.appendChild(bubble);
            } else {
                syncMessageBlocks(row, text);
            }
            els.chatHist.appendChild(row);
            if (!isInit) safeScrollToBottom();
            return row;
        }

        function renderCalc(content, isInit) {
            const card = document.createElement('div');
