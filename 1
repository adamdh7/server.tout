                        });
                        clearTimeout(timeoutId);
                        if (!res.ok) throw new Error("Status error");
                        
                        let typingElement = document.getElementById('typing-indicator');
                        if (typingElement && typingElement.parentElement) {
                            typingElement.parentElement.remove();
                        }
                        
                        const contentType = res.headers.get("content-type");
                        if (contentType && contentType.includes("application/json")) {
                            const data = await res.json();
                            let finalTxt = data.reply || data.message || data.error;
                            if(data.error) throw new Error("Server error");
                            chatData[currentStreamIndex].text = finalTxt;
                            renderChat('ai', finalTxt);
                        } else {
                            let rows = document.querySelectorAll('.message-row.ai');
                            let row = rows[rows.length - 1];
                            if (!row || row.innerText !== '') {
                                row = document.createElement('div');
                                row.className = 'message-row ai';
                                els.chatHist.appendChild(row);
                            } else {
                                row.innerHTML = '';
                            }
                            
                            const reader = res.body.getReader();
                            const decoder = new TextDecoder("utf-8");
                            let aiFullText = "";
                            
                            while (true) {
                                const { done, value } = await reader.read();
                                if (done) break;
                                aiFullText += decoder.decode(value, { stream: true });
                                chatData[currentStreamIndex].text = aiFullText;
                                syncMessageBlocks(row, aiFullText);
                                safeScrollToBottom();
                            }
                        }
                        success = true;
                        break;
                    } catch (e) {
                        clearTimeout(timeoutId);
                        let rows = document.querySelectorAll('.message-row.ai');
                        let row = rows[rows.length - 1];
                        if (row && row.innerText === '') {
                            row.remove();
                        }
                    }
                }
                
                if (!success) {
                    let typingElement = document.getElementById('typing-indicator');
                    if (typingElement && typingElement.parentElement) {
                        typingElement.parentElement.remove();
                    }
                    chatData.splice(currentStreamIndex, 1);
                    showError("Serveur Ai indisponible.");
                }
                
                isStreaming = false;
                els.scrollBtn.classList.remove('show');
                localStorage.setItem('chat_messages', JSON.stringify(chatData));

