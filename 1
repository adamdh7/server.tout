        function copyCode(event, el) {
            event.stopPropagation();
            let rawData = el.getAttribute('data-raw');
            if (!rawData) return;
            navigator.clipboard.writeText(decodeURIComponent(rawData)).then(() => {
                let feedback = el.querySelector('.copy-feedback');
                if (feedback) {
                    feedback.innerText = "Copié!";
                    feedback.classList.add('show');
                    setTimeout(() => feedback.classList.remove('show'), 1500);
                }
            });
        }

        function formatText(text) {
            if (!text) return "";
            let p = text;
            p = p.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
            p = p.replace(/`([^`]+)`/g, function(match, p1) {
                let raw = encodeURIComponent(p1);
                return '<code class="copyable-code" data-raw="'+raw+'" onclick="copyCode(event, this)">'+p1+'<span class="copy-feedback"></span></code>';
            });
            p = p.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
            p = p.replace(/^[ \t]*\*[ \t]+/gm, '• ');
            p = p.replace(/\n/g, '<br>');
            return p;
        }

        function syncMessageBlocks(row, text) {
            row.innerHTML = '';
            let firstTick = text.indexOf('```');
            let parts = [];
            
            if (firstTick !== -1) {
                let lastTick = text.lastIndexOf('```');
                if (lastTick > firstTick) {
                    parts.push({ type: 'normal', content: text.substring(0, firstTick) });
                    parts.push({ type: 'raw', content: text.substring(firstTick + 3, lastTick) });
                    parts.push({ type: 'normal', content: text.substring(lastTick + 3) });
                } else {
                    parts.push({ type: 'normal', content: text.substring(0, firstTick) });
                    parts.push({ type: 'raw', content: text.substring(firstTick + 3) });
                }
            } else {
                parts.push({ type: 'normal', content: text });
            }
            
            parts.forEach(function(p) {
                if (p.content.trim() === '') return;
                if (p.type === 'raw') {
                    let div = document.createElement('div');
                    div.className = 'raw-text copyable-code';
                    let rawSafe = encodeURIComponent(p.content);
                    div.setAttribute('data-raw', rawSafe);

                    div.addEventListener('touchstart', function(e) { handleCodeTouchStart(e, p.content); }, {passive: true});
                    div.addEventListener('touchend', handleCodeTouchEnd);
                    div.addEventListener('touchmove', handleCodeTouchEnd);
                    div.addEventListener('mousedown', function(e) { handleCodeTouchStart(e, p.content); });
                    div.addEventListener('mouseup', handleCodeTouchEnd);
                    div.addEventListener('mouseleave', handleCodeTouchEnd);
                    div.addEventListener('contextmenu', function(e) { e.preventDefault(); openActionMenu(p.content); });
                    
                    div.onclick = function(e) { copyCode(e, this); };

                    div.innerHTML = p.content.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;') + '<span class="copy-feedback"></span>';
                    row.appendChild(div);
                } else {
                    let mediaRegex = /(https?:\/\/[^\s<]+)/g;
                    let subParts = p.content.split(mediaRegex).filter(Boolean);
                    
                    let currentBubbleText = '';
                    const flushBubble = function() {
                        let cleaned = currentBubbleText.replace(/^(<br>|\s)+|( <br>|\s)+$/g, '').trim();
                        if (cleaned !== '') {
                            let b = document.createElement('div');
                            b.className = 'bubble';
                            b.innerHTML = formatText(cleaned);
                            row.appendChild(b);
                        }
                        currentBubbleText = '';
                    };

                    subParts.forEach(function(sp) {
                        if (sp.match(/^https?:\/\//)) {
                            let lowerUrl = sp.toLowerCase();
                            let isMedia = false;
                            
                            if (lowerUrl.match(/\.(jpeg|jpg|gif|png|webp|bmp)(\?.*)?$/) || sp.includes('bref.adamdh7.org')) {
                                flushBubble();
                                let img = document.createElement('img');
                                img.className = 'chat-media';
                                img.src = sp;
                                if (!lowerUrl.includes('bref.adamdh7.org')) img.onclick = function() { window.open(sp, '_blank'); };
                                row.appendChild(img);
                                isMedia = true;
                            } else if (lowerUrl.match(/\.(mp4|webm|mov)(\?.*)?$/)) {
                                flushBubble();
                                let vid = document.createElement('video');
                                vid.controls = true;
                                vid.className = 'chat-media';
                                vid.src = sp;
                                row.appendChild(vid);
                                isMedia = true;
                            } else if (lowerUrl.includes('youtube.com/watch') || lowerUrl.includes('youtu.be/')) {
                                flushBubble();
                                let vId = lowerUrl.includes('youtu.be/') ? sp.split('youtu.be/')[1].split(/[?#]/)[0] : sp.match(/[?&]v=([^&]+)/)?.[1];
                                if (vId) {
                                    let ifr = document.createElement('iframe');
                                    ifr.className = 'chat-media';
                                    ifr.style.aspectRatio = '16/9';
                                    ifr.style.width = '100%';
                                    ifr.style.border = 'none';
                                    ifr.allowFullscreen = true;
                                    ifr.src = 'https://www.youtube.com/embed/' + vId;
                                    row.appendChild(ifr);
                                    isMedia = true;
                                }
                            }
                            if (!isMedia) currentBubbleText += sp;
                        } else {
                            currentBubbleText += sp;
                        }
                    });
                    flushBubble();
                }
            });
        }

        function renderChat(role, text, isTyping, isInit) {
            const row = document.createElement('div');
            row.className = 'message-row ' + role;
            if (isTyping) {
                const bubble = document.createElement('div');
